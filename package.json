{
  "name": "@loongphy/codex-auth",
  "version": "0.2.2-alpha.1",
  "description": "CLI for switching Codex accounts",
  "main": "manager/electron-main.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/soicoi/codex-account-manager.git"
  },
  "homepage": "https://github.com/soicoi/codex-account-manager",
  "bugs": {
    "url": "https://github.com/soicoi/codex-account-manager/issues"
  },
  "bin": {
    "codex-auth": "bin/codex-auth.js"
  },
  "files": [
    "bin/",
    "LICENSE",
    "README.md"
  ],
  "optionalDependencies": {
    "@loongphy/codex-auth-darwin-arm64": "0.2.2-alpha.1",
    "@loongphy/codex-auth-darwin-x64": "0.2.2-alpha.1",
    "@loongphy/codex-auth-linux-x64": "0.2.2-alpha.1",
    "@loongphy/codex-auth-win32-x64": "0.2.2-alpha.1"
  },
  "scripts": {
    "manager:start": "electron manager/electron-main.js",
    "manager:desktop": "electron manager/electron-main.js",
    "manager:web": "node manager/server.js",
    "manager:dev": "node --watch manager/server.js",
    "manager:build": "electron-builder --win portable zip",
    "check:versions": "node scripts/npm/check-versions.mjs",
    "stage:npm": "node scripts/npm/stage-packages.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@loongphy/codex-auth": "^0.2.1",
    "@openai/codex": "^0.116.0"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.kendy.codex-account-manager",
    "productName": "Codex Account Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "manager/**/*",
      "package.json",
      "!src{,/**/*}",
      "!docs{,/**/*}",
      "!scripts{,/**/*}",
      "!plans{,/**/*}",
      "!bin{,/**/*}",
      "!build.zig",
      "!AGENTS.md",
      "!README.md"
    ],
    "asarUnpack": [
      "node_modules/@loongphy/**/*",
      "node_modules/@openai/**/*",
      "manager/assets/**/*"
    ],
    "npmRebuild": false,
    "publish": null,
    "win": {
      "icon": "manager/assets/app-icon.ico",
      "target": [
        "portable",
        "zip"
      ],
      "artifactName": "Codex-Account-Manager-${version}-${arch}.${ext}"
    }
  }
}
